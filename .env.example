# Copy to .env.local and fill in values. Never commit .env.local.

# Google Tag Manager (GTM). Leave empty to disable GTM entirely.
# Example: GTM-ABC1234
NEXT_PUBLIC_GTM_ID=

# Formspree form endpoint IDs (the bit after formspree.io/f/).
# Get these from https://formspree.io after creating each form.
NEXT_PUBLIC_FORMSPREE_CARE_SEEKER_ID=
NEXT_PUBLIC_FORMSPREE_CAREGIVER_ID=

# Social URLs — only set these when real Allegiant accounts exist.
# Missing values hide the icon (never fall back to placeholders).
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_YOUTUBE=

# Set to 1 to force the text wordmark fallback (useful during staging if the
# /public/logo.png asset needs to be replaced). Leave empty in production.
NEXT_PUBLIC_NO_LOGO=
